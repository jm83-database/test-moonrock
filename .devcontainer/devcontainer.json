{
  "name": "Fixed Python & Node Dev",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance"
      ]
    }
  },
  // 명령어가 실패해도 컨테이너는 뜨도록 분리
  "updateContentCommand": "python3 -m pip install -r requirements.txt || echo 'pip install failed but continuing...'",
  "hostRequirements": {
    "cpus": 4
  }
}
